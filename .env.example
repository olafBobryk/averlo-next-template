# Set to "icon" for a plain organization icon; profile-picture is the default.
# NEXT_PUBLIC_ORGANIZATION_IDENTITY_VISUAL=icon

# Dashboard support mailto destination. The support fixture form never sends email.
# SUPPORT_EMAIL=support@example.com

# Optional production password-recovery delivery through Resend.
# APP_ORIGIN=https://example.com
# RESEND_API_KEY=
# PASSWORD_RESET_FROM="Averlo <security@example.com>"
