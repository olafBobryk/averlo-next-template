{
	"name": "webvizion-template",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"intelligence:generate": "node scripts/generate-template-intelligence.mjs",
		"intelligence:query": "node scripts/generate-template-intelligence.mjs --query",
		"intelligence:record": "node scripts/record-template-intelligence-benchmark.mjs",
		"intelligence:record:clear": "node scripts/clear-template-intelligence-benchmark.mjs",
		"intelligence:serena:setup": "node scripts/setup-template-intelligence-serena.mjs",
		"predev": "npm run intelligence:generate",
		"predev:user": "npm run intelligence:generate",
		"predev:agent": "npm run intelligence:generate",
		"prebuild": "npm run intelligence:generate",
		"dev": "node scripts/dev-server.mjs user",
		"dev:user": "node scripts/dev-server.mjs user",
		"dev:agent": "node scripts/dev-server.mjs agent",
		"build": "next build --turbopack",
		"start": "next start",
		"lint": "biome check",
		"typecheck": "tsc --noEmit --pretty false",
		"verify:static": "npm run lint && npm run typecheck",
		"verify:build": "npm run build",
		"verify:smoke": "node scripts/verify-smoke.mjs",
		"verify": "npm run verify:static && npm run verify:build && npm run verify:smoke",
		"format": "biome format --write",
		"create:thin-start": "node scripts/create-thin-start.mjs",
		"review:thin-start-api": "node scripts/review-thin-start-api.mjs",
		"prune:template": "node scripts/prune-template.mjs",
		"postinstall": "node scripts/pin-deps.mjs",
		"postbuild": "node scripts/postbuild.mjs"
	},
	"dependencies": {
